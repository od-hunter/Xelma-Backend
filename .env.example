# Server Configuration
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/xelma_db

# JWT Configuration
# IMPORTANT: Change this to a strong, random secret in production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=7d

# Xelma Bindings – API Key
# Required to authenticate requests made with @tevalabs/xelma-bindings
# Obtain your key from the TevaLabs dashboard or from the project maintainers
XELMA_API_KEY=your-xelma-api-key-here

# Soroban Network Configuration
# Options: 'mainnet' or 'testnet'
SOROBAN_NETWORK=testnet

# Soroban Smart Contract Configuration
# RPC endpoint for Soroban contract calls
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed Xelma prediction market contract ID
# Get this from the Xelma-Blockchain deployment
SOROBAN_CONTRACT_ID=your-contract-id-here

# Admin keypair secret key (for creating rounds)
# This should be the admin address used when initializing the contract
SOROBAN_ADMIN_SECRET=S...your-admin-secret-key-here

# Oracle keypair secret key (for resolving rounds)
# This should be the oracle address used when initializing the contract
SOROBAN_ORACLE_SECRET=S...your-oracle-secret-key-here

# Round Scheduler (cron for creating/closing rounds)
# Set to "true" to enable scheduled round creation every 4 min and locking every 30s
ROUND_SCHEDULER_ENABLED=false
# Game mode for scheduled rounds: UP_DOWN or LEGENDS
ROUND_SCHEDULER_MODE=UP_DOWN

# -----------------------
# Redis Cache (Optional)
# -----------------------
# Leave undefined/empty to disable Redis-backed caching entirely.
REDIS_URL=redis://localhost:6379

# Set to "false" to disable Redis caching even if REDIS_URL is present.
REDIS_CACHE_ENABLED=true

# Leaderboard pagination cache TTL (seconds).
LEADERBOARD_CACHE_TTL_SECONDS=60

# Static educational guides cache TTL (seconds).
EDUCATION_GUIDES_CACHE_TTL_SECONDS=86400

# Prefix for all Redis cache keys.
REDIS_CACHE_PREFIX=xelma:cache

# Cooldown after a failed Redis connect/ping (ms) before retrying.
REDIS_FAIL_COOLDOWN_MS=10000
